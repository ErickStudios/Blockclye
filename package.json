{
  "name": "Blockclye",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.blockclye.app",
    "productName": "Blockclye",
    "files": [
      "**/*",
      "!dist",
      "!node_modules/.cache",
      "!*.log",
      "!temp",
      "!payload.zip"
    ],
    "icon": "icon.ico",
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
